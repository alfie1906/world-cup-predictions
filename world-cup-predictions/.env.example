# Example environment variables

# Google Sheets CSV export URL (optional). If provided the app will fetch predictions from here
VITE_SHEETS_CSV=""

# Google Sheets CSV export URL for the Results tab.
# Expected headers: Match, Fixture ID, Result
VITE_RESULTS_CSV=""

# Optional Google Apps Script web app URL. If provided, the app will update
# existing Results rows with H/X/A results found via TheSportsDB.
VITE_RESULTS_WEB_APP_URL=""

# Optional: a custom fixtures API (if you have a different provider)
VITE_FIXTURES_API=""

# TheSportsDB settings (use the free key '123' if you don't have a different key)
# This will be used by the app and by the scripts/generate-fixtures-lookup.cjs script
VITE_THESPORTSDB_APIKEY="123"
VITE_THESPORTSDB_LEAGUE_ID=""

# For running the Node script directly, these env vars are also supported (script prefers these names):
THESPORTSDB_APIKEY="123"
THESPORTSDB_LEAGUE_ID=""

# Notes:
# - To use TheSportsDB fetching, set the LEAGUE_ID to the ID of the competition you want.
# - After running the generator script (npm run generate:fixtures-lookup), copy the generated
#   public/fixtures-lookup.json contents into your sheet mapping if needed.
